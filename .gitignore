# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==========================================
# Dependencies
# ==========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==========================================
# Environment & Secrets — NEVER commit these
# ==========================================
.env
.env.*
!.env.example       # Allow only the example template
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
secrets/
.secrets/

# ==========================================
# Next.js
# ==========================================
/.next/
/out/
/build

# ==========================================
# Supabase local dev
# ==========================================
/supabase/.branches
/supabase/.temp

# ==========================================
# Testing & Coverage
# ==========================================
/coverage
/.nyc_output

# ==========================================
# Debug logs
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ==========================================
# OS & Editor artifacts
# ==========================================
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ==========================================
# Vercel deployment
# ==========================================
.vercel

# ==========================================
# TypeScript
# ==========================================
*.tsbuildinfo
next-env.d.ts
